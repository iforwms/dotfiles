#!/bin/bash

destination="/Users/ifor/Documents/backup/db_json"
today="$(date +%Y-%m-%d)"
KEEP=3

echo "Backing up pool stats..."
filename="backup_pool_stats_${today}"
base_dir="/var/www/pool_stats/db"
rsync --verbose --times --compress "me:${base_dir}/pool.sqlite" "${destination}/${filename}.sqlite"

echo "Backing up grocy..."
base_dir="/var/www/grocy/data/backups"
rsync --verbose --archive --delete-delay --partial --compress "me:${base_dir}/" "${destination}/grocy/"

echo "Backing up gridfinity..."
base_dir="/var/www/gridfinity-inventory"
rsync --verbose --times --compress "me:${base_dir}/gridfinity.sqlite" "${destination}/gridfinity/gridfinity-${today}.sqlite"

echo "Backing up filamentz..."
filename="filamentz_${today}"
base_dir="/var/www/filamentz"
rsync --verbose --times --compress "me:${base_dir}/filament-db.json" "${destination}/${filename}.json"

echo "Backing up kuaidi..."
filename="backup_kuaidi_${today}"
base_dir="/var/www/kuaidi/db"
rsync --verbose --times --compress "me:${base_dir}/*" "${destination}/kuaidi"

echo "Backing up ego buster..."
base_dir="/var/www/ego_buster"
rsync --verbose --times --compress "me:${base_dir}/results/*" "${destination}/ego_buster/results_${today}"

echo "Backing up gridfinity..."
base_dir="/var/www/gridfinity-inventory"
rsync --verbose --times --compress "me:${base_dir}/gridfinity.sqlite" "${destination}/gridfinity/gridfinity-${today}.sqlite"

echo "Backing up jukebox..."
base_dir="/var/www/jukebox"
rsync --verbose --times --compress "me:${base_dir}/mb_db/*" "${destination}/jukebox/mb_db"
rsync --verbose --times --compress "me:${base_dir}/album_art/*" "${destination}/jukebox/album_art"
rsync --verbose --times --compress "me:${base_dir}/jukebox.sqlite" "${destination}/jukebox/jukebox-${today}.sqlite"

echo "Backing up darts stats..."
filename="backup_darts_stats_${today}"
base_dir="/var/www/darts/db"
rsync --verbose --times --compress "me:${base_dir}/players.json" "${destination}/${filename}_players.json"
rsync --verbose --times --compress "me:${base_dir}/matches.json" "${destination}/${filename}_matches.json"

echo "Backing up year planner..."
filename="backup_year_planner_${today}"
base_dir="/var/www/year_planner/db"
rsync --verbose --times --compress "me:${base_dir}/data.json" "${destination}/${filename}_data.json"

echo "Backing up basketball shooting logger..."
filename="backup_bbsl_${today}"
base_dir="/var/www/basketball_shooting_log"
rsync --verbose --times --compress "me:${base_dir}/bbsl.json" "${destination}/${filename}.json"

echo "Backing up pedalboard settings..."
rsync --verbose --times --compress -r me:/var/www/pedalboard/db/* "${destination}/pedbalboard"

# Args: paths in one backup family (e.g. backup_bbsl_*.json).
# Always deletes empty files/dirs. Keeps the newest $KEEP non-empty ones;
# deletes the rest. "Newest" is by filename — date is YYYY-MM-DD so lex sort works.
prune_backups() {
  local entry kept=0
  for entry in $(printf '%s\n' "$@" | sort -r); do
    if [[ -d "$entry" ]]; then
      if [[ -z "$(ls -A "$entry" 2>/dev/null)" ]]; then
        echo "  rm (empty dir):  $entry"; rm -rf -- "$entry"; continue
      fi
    elif [[ ! -s "$entry" ]]; then
      echo "  rm (empty file): $entry"; rm -- "$entry"; continue
    fi
    if (( kept < KEEP )); then ((kept++)); continue; fi
    if [[ -d "$entry" ]]; then
      echo "  rm (old dir):    $entry"; rm -rf -- "$entry"
    else
      echo "  rm (old file):   $entry"; rm -- "$entry"
    fi
  done
}

echo "Cleaning up old backups (keeping newest $KEEP non-empty)..."
shopt -s nullglob
prune_backups "${destination}"/backup_pool_stats_*.sqlite
prune_backups "${destination}"/backup_bbsl_*.json
prune_backups "${destination}"/backup_darts_stats_*_players.json
prune_backups "${destination}"/backup_darts_stats_*_matches.json
prune_backups "${destination}"/backup_year_planner_*_data.json
prune_backups "${destination}"/filamentz_*.json
prune_backups "${destination}"/gridfinity/gridfinity-*.sqlite
prune_backups "${destination}"/jukebox/jukebox-*.sqlite
prune_backups "${destination}"/ego_buster/results_*
shopt -u nullglob

